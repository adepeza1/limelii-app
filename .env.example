# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and will only be used by `npm run dev` on your laptop.
#
# For local development, create a SEPARATE Kinde application (do not reuse
# your production Kinde credentials). See README.md "Local Development".

# --- Kinde (required) ---
# From your Kinde dev application's "Details" page.
KINDE_CLIENT_ID=
KINDE_CLIENT_SECRET=
# Your Kinde subdomain, e.g. https://your-tenant.kinde.com
KINDE_ISSUER_URL=
# Must match what you registered in Kinde for local dev.
KINDE_SITE_URL=http://localhost:3000
KINDE_POST_LOGIN_REDIRECT_URL=http://localhost:3000/auth/callback
KINDE_POST_LOGOUT_REDIRECT_URL=http://localhost:3000

# --- Mixpanel (optional) ---
# Leave blank to disable analytics in dev.
NEXT_PUBLIC_MIXPANEL_TOKEN=
